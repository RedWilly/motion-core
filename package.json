{
  "name": "motion-core",
  "version": "0.1.0",
  "description": "Typed 2D motion composition core for Scrawl-canvas rendering, GSAP timelines, and Mediabunny media export.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./animation": {
      "types": "./dist/animation.d.ts",
      "import": "./dist/animation.js",
      "require": "./dist/animation.cjs"
    },
    "./export": {
      "types": "./dist/export.d.ts",
      "import": "./dist/export.js",
      "require": "./dist/export.cjs"
    },
    "./audio": {
      "types": "./dist/audio.d.ts",
      "import": "./dist/audio.js",
      "require": "./dist/audio.cjs"
    },
    "./integration": {
      "types": "./dist/integration.d.ts",
      "import": "./dist/integration.js",
      "require": "./dist/integration.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "fast-check": "^4.7.0",
    "gsap": "^3.15.0",
    "mediabunny": "^1.44.0",
    "scrawl-canvas": "^8.18.0",
    "typescript": "^5.9.3",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "gsap": "^3.15.0",
    "mediabunny": "^1.44.0",
    "scrawl-canvas": "^8.18.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "keywords": [
    "2d",
    "motion-graphics",
    "video",
    "video-export",
    "animation",
    "timeline",
    "compositing",
    "canvas",
    "webcodecs",
    "typescript",
    "gsap",
    "scrawl-canvas",
    "mediabunny"
  ]
}
